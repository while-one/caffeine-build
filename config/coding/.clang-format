# .clang-format for Caffeine (BARR-C:2018 Compliant)
---
Language: Cpp
BasedOnStyle: LLVM

# --- Section 1: Indentation & Tabs (Rule 3.4 & 3.5) ---
IndentWidth: 4
UseTab: Never
ContinuationIndentWidth: 4

# --- Section 2: Line Width (Rule 1.2) ---
# OVERRIDE: Limits width to a maximum of 80 characters. Expanded to 120
ColumnLimit: 120

# --- Section 3: Braces & Control Structures (Rule 1.3) ---
# Braces shall always surround blocks of code, following Allman style
BreakBeforeBraces: Allman
AllowShortBlocksOnASingleLine: false
AllowShortFunctionsOnASingleLine: Empty
AllowShortIfStatementsOnASingleLine: false
AllowShortLoopsOnASingleLine: false
Cpp11BracedListStyle: false
InsertBraces: true

# --- Section 4: Whitespace & Parentheses (Rule 3.1) ---
SpaceAfterCStyleCast: true
SpacesInParentheses: false
SpaceBeforeAssignmentOperators: true
SpaceBeforeRangeBasedForLoopColon: true
SpaceInEmptyParentheses: false

# Enforces space after keywords (if, while, etc.) and before function names
SpaceBeforeParens: Custom
SpaceBeforeParensOptions:
  AfterControlStatements: true
  AfterFunctionDefinitionName: true
  AfterFunctionDeclarationName: true
  AfterIfMacros: true

# --- Section 5: Switch Statements (Rule 3.4.b & 8.3) ---
IndentCaseLabels: true
IndentCaseBlocks: false

# --- Section 6: Pointers & Declarations (Rule 3.1.e) ---
# OVERRIDE: BARR-C:2018 mandates whitespace on both sides (Middle).
# Modified to 'Right'
PointerAlignment: Right
AlignConsecutiveMacros: true
AlignConsecutiveDeclarations: true
AlignConsecutiveAssignments:
  Enabled: true
  AcrossEmptyLines: true
  AcrossComments: true
AlignArrayOfStructures: Left

# --- Section 7: Includes & Cleanup (Rule 3.3.b & 3.6.a) ---
SortIncludes: false
MaxEmptyLinesToKeep: 1
KeepEmptyLinesAtTheStartOfBlocks: false
# Enforces 'LF' line endings exclusively, forbidding 'CR'-'LF'
UseCRLF: false 

# --- Section 8: Formatting Behavior (Rule 6.2 & General Examples) ---
AlignAfterOpenBracket: Align
# Breaks line after the return type of a function definition
AlwaysBreakAfterReturnType: AllDefinitions
PenaltyReturnTypeOnItsOwnLine: 60
BreakBeforeBinaryOperators: None
IndentExternBlock: NoIndent
BinPackArguments: false
BinPackParameters: false
