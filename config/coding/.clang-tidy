# .clang-tidy for Caffeine Framework (BARR-C:2018 Compliant - Pragmatic Adjustments)
---
# Enable specific check groups
Checks: >
  -*,
  bugprone-*,
  performance-*,
  portability-*,
  readability-identifier-naming,
  readability-identifier-length,
  readability-braces-around-statements,
  readability-function-size,
  readability-misleading-indentation,
  readability-redundant-declaration,
  readability-implicit-bool-conversion,
  readability-else-after-return,
  readability-isolate-declaration,
  readability-magic-numbers,
  modernize-use-stdint,
  clang-analyzer-core.*,
  clang-analyzer-valist.*,
  clang-analyzer-deadcode.DeadStores,
  cert-err33-c,
  bugprone-assignment-in-if-condition,
  bugprone-string-constructor,
  bugprone-signed-char-misuse,
  bugprone-unused-return-value,
  bugprone-string-literal-with-embedded-nul,
  bugprone-suspicious-missing-comma,
  bugprone-unhandled-self-assignment,
  bugprone-narrowing-conversions,
  bugprone-switch-missing-default-case,
  bugprone-implicit-widening-of-multiplication-result,
  bugprone-implicit-fallthrough,
  bugprone-compare-float,
  misc-const-correctness,
  google-runtime-int,
  readability-uppercase-literal-suffix,
  hicpp-signed-bitwise,
  hicpp-avoid-goto,
  readability-non-const-parameter,
  readability-static-definition-in-anonymous-namespace,
  -bugprone-easily-swappable-parameters

# Warnings as errors ensures any violation blocks the CI pipeline
WarningsAsErrors: '*'

CheckOptions:
  - { key: readability-braces-around-statements.ShortIfStatementsOnSingleLine, value: false }
  - { key: readability-isolate-declaration.AggregateThreshold,    value: 1 }
  - { key: readability-identifier-naming.MacroDefinitionCase,     value: UPPER_CASE }
  - { key: readability-identifier-naming.ConstantCase,            value: UPPER_CASE }
  - { key: readability-identifier-naming.EnumConstantCase,        value: UPPER_CASE }
  - { key: readability-make-member-function-const.IgnoreMacros,   value: true }
  - { key: readability-non-const-parameter.IgnoreMacros,          value: true }
  - { key: readability-uppercase-literal-suffix.NewSuffixes,      value: 'L;LL;U;UL;ULL;F' }
  
  # --- Variable and Function Casing ---
  # Section 5.1, 6.1, 7.1
  - { key: readability-identifier-naming.VariableCase,            value: lower_case }
  - { key: readability-identifier-naming.ParameterCase,           value: lower_case }
  - { key: readability-identifier-naming.ConstantParameterCase,   value: lower_case }
  - { key: readability-identifier-naming.PointerParameterCase,    value: lower_case }
  - { key: readability-identifier-naming.FunctionCase,            value: lower_case }
  - { key: readability-identifier-naming.GlobalVariableCase,      value: lower_case }
  - { key: readability-identifier-naming.StructCase,              value: lower_case }
  - { key: readability-identifier-naming.EnumCase,                value: lower_case }
  - { key: readability-identifier-naming.UnionCase,               value: lower_case }
  - { key: readability-identifier-naming.TypedefCase,             value: lower_case }
  - { key: readability-identifier-naming.TypeAliasCase,           value: lower_case }
  
  # --- Variable Prefixes ---
  # Global variables must begin with 'g_' (Section 7.1.j)
  - { key: readability-identifier-naming.GlobalVariablePrefix,    value: 'g_' }
  # Pointer variables must begin with 'p_' (Section 7.1.k)
  - { key: readability-identifier-naming.GlobalPointerPrefix,   value: 'p_' }
  - { key: readability-identifier-naming.LocalPointerPrefix,   value: 'p_' }
  - { key: readability-identifier-naming.PointerParameterPrefix,  value: 'p_' }
  
  # --- Data Type Suffixes ---
  # New data types must end with '_t' (Section 5.1.a)
  - { key: readability-identifier-naming.TypedefSuffix,           value: '_t' }
  - { key: readability-identifier-naming.TypeAliasSuffix,         value: '_t' }
  
  

  # --- Identifier Length Limits ---
  # Kept strict 3-character minimum (Section 7.1.e). 
  - { key: readability-identifier-length.MinimumVariableNameLength, value: 3 }
  
  # OVERRIDE: BARR-C Rule 7.1.d (Page 48) & 6.1.d (Page 40) limits names to 31 chars.
  # Expanded to 64 to practically accommodate modern HAL/RTOS prefixes and descriptive names.
  - { key: readability-identifier-length.MaximumVariableNameLength, value: 64 }
  - { key: readability-identifier-length.MaximumFunctionNameLength, value: 64 }

  # --- Function Size Limits ---
  # Functions limited to a maximum of 100 lines (Section 6.2.a)
  - { key: readability-function-size.LineThreshold,               value: 100 }
  - { key: readability-function-size.BranchThreshold,             value: 10 }

  # --- Narrowing, Sizeof, and Switch Checks ---
  - { key: bugprone-narrowing-conversions.WarnOnIntegerNarrowing,       value: true }
  - { key: bugprone-narrowing-conversions.WarnOnFloatingPointNarrowing, value: true }
  
  # OVERRIDE: Pedantic mode disabled to prevent excessive noise on safe hardware register bit-shifts,
  # keeping the linter practical for embedded development.
  - { key: bugprone-narrowing-conversions.PedanticMode,                 value: false }
  
  - { key: bugprone-sizeof-expression.WarnOnSizeOfConstant,             value: true }
  - { key: bugprone-sizeof-expression.WarnOnSizeOfIntegerConstant,      value: true }
  - { key: hicpp-signed-bitwise.IgnorePositiveIntegerLiterals,          value: false }
  - { key: bugprone-switch-missing-default-case.CheckSwitchStatements,  value: true }
  
  # --- Magic Numbers ---
  # OVERRIDE: BARR-C Rule 8.4.a (Page 54) forbids magic numbers entirely. 
  # Pragmatically allowing '0' to avoid noise on simple initializations (e.g., buffer[0] = 0).
  - { key: readability-magic-numbers.IgnorePowersOf2IntegerValues,      value: false }
  - { key: readability-magic-numbers.IgnoredIntegerValues,              value: '0' }
  
  # --- Implicit Conversions & Return Values ---
  - { key: readability-implicit-bool-conversion.AllowIntegerContext,    value: false }
  - { key: readability-implicit-bool-conversion.AllowPointerContext,    value: false }
  - { key: bugprone-unused-return-value.CheckedReturnTypes,             value: 'cfn_hal_error_code_t;size_t;ssize_t' }
  - { key: performance-unnecessary-value-param.AllowedTypes,            value: '' }
