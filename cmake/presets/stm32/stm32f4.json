{
  "version": 4,
  "include": [
    "../base.json"
  ],
  "configurePresets": [
    {
      "name": "stm32f4-base-peripheral-set",
      "hidden": true,
      "inherits": "base-hardware-defaults",
      "cacheVariables": {
        "CFN_HAL_ADC": "ON",
        "CFN_HAL_CLOCK": "ON",
        "CFN_HAL_DMA": "ON",
        "CFN_HAL_GPIO": "ON",
        "CFN_HAL_I2C": "ON",
        "CFN_HAL_I2S": "ON",
        "CFN_HAL_IRQ": "ON",
        "CFN_HAL_NVM": "ON",
        "CFN_HAL_PWM": "ON",
        "CFN_HAL_RTC": "ON",
        "CFN_HAL_SDIO": "ON",
        "CFN_HAL_SPI": "ON",
        "CFN_HAL_TIMER": "ON",
        "CFN_HAL_UART": "ON",
        "CFN_HAL_WDT": "ON"
      }
    },
    {
      "name": "stm32f407-peripheral-set",
      "hidden": true,
      "inherits": "stm32f4-base-peripheral-set",
      "cacheVariables": {
        "CFN_HAL_CAN": "ON",
        "CFN_HAL_ETH": "ON",
        "CFN_HAL_USB": "ON"
      }
    },
    {
      "name": "stm32f417-peripheral-set",
      "hidden": true,
      "inherits": "stm32f407-peripheral-set",
      "cacheVariables": {
        "CFN_HAL_CRYPTO": "ON",
        "CFN_HAL_HASH": "ON",
        "CFN_HAL_RNG": "ON"
      }
    },
    {
      "name": "stm32f417vg-release",
      "inherits": [
        "base-arm",
        "stm32f417-peripheral-set"
      ],
      "displayName": "STM32F417VG (ARM Cortex-M4)",
      "binaryDir": "${sourceDir}/build/stm32f417vg-release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CAFFEINE_VENDOR": "stm32",
        "CAFFEINE_PORT_FAMILY": "stm32f4",
        "CAFFEINE_MCU_CORE": "cortex-m4",
        "CAFFEINE_MCU_COMPILE_OPTIONS": "-mfloat-abi=hard -mfpu=fpv4-sp-d16",
        "CAFFEINE_MCU_MACRO": "STM32F417xx",
        "CAFFEINE_LINKER_SCRIPT": "STM32F417VGTX_FLASH.ld"
      }
    },
    {
      "name": "stm32f407-release",
      "inherits": [
        "base-arm",
        "stm32f407-peripheral-set"
      ],
      "displayName": "STM32F407 (ARM Cortex-M4)",
      "binaryDir": "${sourceDir}/build/stm32f407-release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CAFFEINE_VENDOR": "stm32",
        "CAFFEINE_PORT_FAMILY": "stm32f4",
        "CAFFEINE_MCU_CORE": "cortex-m4",
        "CAFFEINE_MCU_COMPILE_OPTIONS": "-mfloat-abi=hard -mfpu=fpv4-sp-d16",
        "CAFFEINE_MCU_MACRO": "STM32F407xx",
        "CAFFEINE_LINKER_SCRIPT": "STM32F407VGTX_FLASH.ld"
      }
    },
    {
      "name": "stm32f407-bootloader",
      "inherits": [
        "base-arm",
        "stm32f407-peripheral-set"
      ],
      "displayName": "STM32F407 w/ Bootloader (32KB Offset)",
      "binaryDir": "${sourceDir}/build/stm32f407-bootloader",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CAFFEINE_VENDOR": "stm32",
        "CAFFEINE_PORT_FAMILY": "stm32f4",
        "CAFFEINE_MCU_CORE": "cortex-m4",
        "CAFFEINE_MCU_COMPILE_OPTIONS": "-mfloat-abi=hard -mfpu=fpv4-sp-d16",
        "CAFFEINE_MCU_MACRO": "STM32F407xx",
        "CAFFEINE_BOOTLOADER_SIZE_HEX": "0x8000",
        "CAFFEINE_LINKER_SCRIPT": "STM32F407VGTX_FLASH.ld"
      }
    }
  ]
}