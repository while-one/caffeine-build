{
  "version": 4,
  "include": [
    "../base.json"
  ],
  "configurePresets": [
    {
      "name": "tests-native",
      "inherits": "base-common",
      "displayName": "Host Mock Tests (GoogleTest)",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/tests-native",
      "cacheVariables": {
        "CFN_HAL_PORT_VENDOR": "mock",
        "CFN_HAL_PORT_FAMILY": "mock-tests"
      }
    }
  ]
}