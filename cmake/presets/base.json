{
  "version": 4,
  "configurePresets": [
    {
      "name": "base-common",
      "hidden": true,
      "cacheVariables": {
        "CAFFEINE_WARNINGS_AS_ERRORS": "ON",
        "CAFFEINE_OPTIMIZATION_LEVEL": "-Os",
        "CAFFEINE_BUILD_STAGE": "build-native"
      }
    },
    {
      "name": "base-unit-tests-gtest",
      "hidden": true,
      "displayName": "Caffeine Unit Tests (Native Host)",
      "description": "Standardized unit test configuration using the host compiler",
      "inherits": "base-common",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/unit-tests-gtest",
      "cacheVariables": {
        "CFN_BUILD_TESTS": "ON"
      }
    },
    {
      "name": "base-hardware-defaults",
      "hidden": true,
      "cacheVariables": {
        "CFN_HAL_ADC": "OFF",
        "CFN_HAL_CAN": "OFF",
        "CFN_HAL_CLOCK": "OFF",
        "CFN_HAL_COMP": "OFF",
        "CFN_HAL_CRYPTO": "OFF",
        "CFN_HAL_DAC": "OFF",
        "CFN_HAL_DMA": "OFF",
        "CFN_HAL_ETH": "OFF",
        "CFN_HAL_GPIO": "OFF",
        "CFN_HAL_I2C": "OFF",
        "CFN_HAL_I2S": "OFF",
        "CFN_HAL_IRQ": "OFF",
        "CFN_HAL_NVM": "OFF",
        "CFN_HAL_PWM": "OFF",
        "CFN_HAL_QSPI": "OFF",
        "CFN_HAL_RTC": "OFF",
        "CFN_HAL_SDIO": "OFF",
        "CFN_HAL_SPI": "OFF",
        "CFN_HAL_TIMER": "OFF",
        "CFN_HAL_UART": "OFF",
        "CFN_HAL_USB": "OFF",
        "CFN_HAL_WDT": "OFF"
      }
    },
    {
      "name": "base-arm",
      "hidden": true,
      "inherits": "base-common",
      "generator": "Ninja",
      "toolchainFile": "${sourceDir}/caffeine-build/cmake/toolchains/arm-gcc.cmake",
      "cacheVariables": {
        "CAFFEINE_BUILD_STAGE": "build-arm"
      }
    },
    {
      "name": "base-riscv",
      "hidden": true,
      "inherits": "base-common",
      "generator": "Ninja",
      "toolchainFile": "${sourceDir}/caffeine-build/cmake/toolchains/riscv-gcc.cmake",
      "cacheVariables": {
        "CAFFEINE_BUILD_STAGE": "build-riscv"
      }
    }
  ]
}
